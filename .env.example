## Fill in your own API keys before running this project.
THREEZERO2_API_KEY=
THREEZERO2_MUSIC_MODEL=chirp-auk
THREEZERO2_MUSIC_TIMEOUT_SECONDS=900
THREEZERO2_SUNO_TAGS=female vocal, nursery rhyme, happy, no intro, no long outro, start singing immediately
THREEZERO2_SUNO_MAX_CHARS=2600
THREEZERO2_IMAGE_MODEL=gpt-image-1-mini
THREEZERO2_IMAGE_SIZE=1024x1024
THREEZERO2_IMAGE_ASPECT_RATIO=16:9
## Optional if you switch the image provider to OpenRouter Gemini Flash:
## OPENROUTER_API_KEY=
## OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
## OPENROUTER_IMAGE_STYLE=Pixar / Disney inspired 3D cartoon style
